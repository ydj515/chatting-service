# Docker Compose
TZ=Asia/Seoul
APP_TIME_ZONE=Asia/Seoul
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api
NGINX_HTTP_PORT=80
CHAT_API_IMAGE=chatting-service-chat-api-application:local
CHAT_WEBSOCKET_IMAGE=chatting-service-chat-websocket-application:local
CHAT_WORKER_IMAGE=chatting-service-chat-worker-application:local
CHAT_ADMIN_IMAGE=chatting-service-chat-admin-application:local

# PostgreSQL
DB_HOST_PORT=5432
DB_REPLICA_HOST_PORT=5433
DB_PORT=5432
DB_READ_PORT=5432
DB_NAME=chatdb
DB_USERNAME=chatuser
DB_PASSWORD=chatpass
DB_TIMEZONE=Asia/Seoul
POSTGRES_REPLICATION_USER=chat_replicator
POSTGRES_REPLICATION_PASSWORD=replicatorpass
POSTGRES_MAX_WAL_SENDERS=10
POSTGRES_MAX_REPLICATION_SLOTS=10
POSTGRES_WAL_KEEP_SIZE=512MB
CHAT_MESSAGE_RETENTION_DAYS=100
CHAT_PARTITION_ARCHIVE_DROP_AFTER_COPY=false
CHAT_PARTITION_ARCHIVE_RUN_ONCE=false
CHAT_PARTITION_ARCHIVE_INTERVAL_SECONDS=86400

# Redis
REDIS_HOST_PORT=6379
REDIS_PORT=6379
REDIS_PASSWORD=
CHAT_REDIS_MEMBERSHIP_TOPIC=chat.membership
CHAT_REDIS_STREAMS_ROOM_STREAM_KEY_PREFIX=chat:stream:room:
CHAT_REDIS_STREAMS_KNOWN_STREAMS_KEY=chat:stream:rooms
CHAT_REDIS_STREAMS_DEAD_LETTER_STREAM_KEY_PREFIX=chat:stream:dlq:
CHAT_REDIS_STREAMS_SHARD_COUNT=1
CHAT_REDIS_STREAMS_MAX_LEN=1000000
CHAT_REDIS_STREAMS_MAX_LEN_APPROXIMATE=true
CHAT_REDIS_ADMISSION_KEY_PREFIX=chat:admission:room:
CHAT_REDIS_ADMISSION_RATE_LIMIT_WINDOW_TTL=2s

# Backend application config
WORKER_ROLES=message-writer,fanout,admin-export,room-policy
CHAT_WORKER_POLL_DELAY_MILLIS=100
CHAT_WORKER_WRITER_CONSUMER_GROUP=message-writer
CHAT_WORKER_WRITER_READ_COUNT=100
CHAT_WORKER_WRITER_MIN_IDLE_MILLIS=30000
CHAT_WORKER_WRITER_CLAIM_INTERVAL_MILLIS=10000
CHAT_WORKER_WRITER_MAX_DELIVERY_COUNT=5
CHAT_WORKER_FANOUT_CONSUMER_GROUP=fanout
CHAT_WORKER_FANOUT_READ_COUNT=100
CHAT_WORKER_FANOUT_MIN_IDLE_MILLIS=30000
CHAT_WORKER_FANOUT_CLAIM_INTERVAL_MILLIS=10000
CHAT_WORKER_FANOUT_MAX_DELIVERY_COUNT=5
CHAT_WORKER_FANOUT_OWNER_LEASE_ENABLED=true
CHAT_WORKER_FANOUT_OWNER_LEASE_TTL_MILLIS=10000
CHAT_WORKER_FANOUT_OWNER_LEASE_RENEW_INTERVAL_MILLIS=3000
CHAT_WORKER_FANOUT_OWNER_LEASE_KEY_PREFIX=chat:fanout:owner:room:
CHAT_WORKER_ROOM_POLICY_POLL_DELAY_MILLIS=1000
CHAT_WORKER_ROOM_SEQ_GAP_AUDIT_ENABLED=true
CHAT_WORKER_ROOM_SEQ_GAP_AUDIT_POLL_DELAY_MILLIS=60000
CHAT_WORKER_ROOM_SEQ_GAP_AUDIT_LOOKBACK=5m
CHAT_ROOM_POLICY_HOT_MESSAGES_PER_SECOND=1000
CHAT_ROOM_POLICY_VERY_HOT_MESSAGES_PER_SECOND=5000
CHAT_ROOM_POLICY_HOT_SHARD_COUNT=16
CHAT_ROOM_POLICY_VERY_HOT_SHARD_COUNT=64
CHAT_ROOM_POLICY_OVERLOAD_WRITER_LAG_MILLIS=3000
CHAT_ROOM_POLICY_OVERLOAD_FANOUT_LAG_MILLIS=3000
CHAT_ROOM_POLICY_OVERLOAD_GATEWAY_QUEUE_DEPTH=128
CHAT_ROOM_POLICY_NORMAL_LIVE_FEED_MAX_MESSAGES=1000
CHAT_ROOM_POLICY_NORMAL_LIVE_FEED_MAX_AGE_SECONDS=60
CHAT_ROOM_POLICY_VERY_HOT_LIVE_FEED_MAX_MESSAGES=500
CHAT_ROOM_POLICY_VERY_HOT_LIVE_FEED_MAX_AGE_SECONDS=30
CHAT_ROOM_POLICY_OVERLOAD_LIVE_FEED_MAX_MESSAGES=300
CHAT_ROOM_POLICY_OVERLOAD_LIVE_FEED_MAX_AGE_SECONDS=15
CHAT_ROOM_POLICY_VERY_HOT_ROOM_RATE_LIMIT_PER_SECOND=5000
CHAT_ROOM_POLICY_OVERLOAD_ROOM_RATE_LIMIT_PER_SECOND=1000
CHAT_ROOM_POLICY_HOT_SLOW_MODE_SECONDS=1
CHAT_ROOM_POLICY_VERY_HOT_SLOW_MODE_SECONDS=1
CHAT_ROOM_POLICY_OVERLOAD_SLOW_MODE_SECONDS=3
CHAT_ROOM_POLICY_TRAFFIC_KEY_PREFIX=chat:room-traffic:
CHAT_ROOM_POLICY_ACTIVE_ROOMS_KEY=chat:room-traffic:active-rooms
CHAT_ROOM_POLICY_TRAFFIC_WINDOW_SECONDS=60
CHAT_ROOM_POLICY_TRAFFIC_COUNTER_TTL_SECONDS=120
CHAT_AUTH_SESSION_SECRET=local-development-session-secret-change-me
CHAT_AUTH_SESSION_TTL=12h
CHAT_AUTH_SESSION_TOKEN_QUERY_PARAM=token
CHAT_AUTH_WEB_SOCKET_TICKET_TTL=30s
CHAT_AUTH_WEB_SOCKET_TICKET_QUERY_PARAM=ticket
CHAT_AUTH_WEB_SOCKET_TICKET_RATE_LIMIT_WINDOW=1m
CHAT_AUTH_WEB_SOCKET_TICKET_RATE_LIMIT_PER_USER=10
CHAT_AUTH_WEB_SOCKET_TICKET_RATE_LIMIT_PER_IP=60
CHAT_AUTH_WEB_SOCKET_TICKET_SESSION_FALLBACK_ENABLED=false
CHAT_API_CORS_ALLOWED_ORIGINS=*
CHAT_ADMIN_CORS_ALLOWED_ORIGINS=*
CHAT_WEBSOCKET_ALLOWED_ORIGINS=*
CHAT_WEBSOCKET_ENDPOINT=/ws/chat
CHAT_WEBSOCKET_GATEWAY_HEARTBEAT_ENABLED=true
CHAT_WEBSOCKET_GATEWAY_HEARTBEAT_INTERVAL_MILLIS=30000
CHAT_WEBSOCKET_GATEWAY_HEARTBEAT_SCHEDULER_POLL_INTERVAL_MILLIS=10000
CHAT_WEBSOCKET_GATEWAY_HEARTBEAT_TIMEOUT_MILLIS=90000
CHAT_WEBSOCKET_GATEWAY_OUTBOUND_QUEUE_MAX_PENDING_MESSAGES=128
CHAT_WEBSOCKET_GATEWAY_OUTBOUND_EXECUTOR_THREADS=32
CHAT_WEBSOCKET_GATEWAY_OUTBOUND_SEND_TIME_LIMIT_MILLIS=10000
CHAT_WEBSOCKET_GATEWAY_OUTBOUND_SEND_BUFFER_SIZE_LIMIT_BYTES=524288
CHAT_MESSAGE_PAGINATION_DEFAULT_LIMIT=50
CHAT_MESSAGE_PAGINATION_MAX_LIMIT=100
CHAT_MESSAGE_SEQUENCE_TTL=24h
CHAT_CACHE_DEFAULT_TTL=30m
CHAT_CACHE_USERS_TTL=1h
CHAT_CACHE_CHAT_ROOMS_TTL=15m
CHAT_CACHE_CHAT_ROOM_MEMBERS_TTL=10m
CHAT_CACHE_MESSAGES_TTL=5m
CHAT_CACHE_ROOM_ADMISSION_POLICIES_TTL=10s
CHAT_CACHE_ROOM_SHARD_CONFIGS_TTL=10s
CHAT_CACHE_MODERATION_RULES_TTL=10s
CHAT_CACHE_USER_SANCTIONS_TTL=10s
CHAT_ADMIN_TOKEN=my-secure-admin-token-change-me

# Object Storage / MinIO
CHAT_OBJECT_STORAGE_ENABLED=true
CHAT_OBJECT_STORAGE_ENDPOINT=http://minio:9000
# presigned download URL용 공개 endpoint(브라우저 접근 주소). 비우면 ENDPOINT로 폴백
CHAT_OBJECT_STORAGE_PUBLIC_ENDPOINT=http://127.0.0.1:9000
CHAT_OBJECT_STORAGE_REGION=us-east-1
CHAT_OBJECT_STORAGE_BUCKET=chat-archives
CHAT_OBJECT_STORAGE_ACCESS_KEY=chatminio
CHAT_OBJECT_STORAGE_SECRET_KEY=chatminiosecret
CHAT_OBJECT_STORAGE_PATH_STYLE_ACCESS=true
CHAT_OBJECT_STORAGE_ADMIN_EXPORT_PREFIX=admin-exports
CHAT_OBJECT_STORAGE_PRESIGNED_URL_TTL=15m
MINIO_ROOT_USER=chatminio
MINIO_ROOT_PASSWORD=chatminiosecret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 관측(Observability) - Prometheus / Grafana
# 포트는 docker-compose에서 호스트 로컬(127.0.0.1)에만 바인딩된다.
PROMETHEUS_PORT=9090
CHAT_PROMETHEUS_URL=http://localhost:9090
GRAFANA_PORT=3000
# Grafana 관리자 비밀번호. production에서는 반드시 강한 값으로 변경한다(기본값 admin 금지).
GRAFANA_ADMIN_PASSWORD=change-me
