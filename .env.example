# Docker Compose
TZ=Asia/Seoul
APP_TIME_ZONE=Asia/Seoul
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api
NGINX_HTTP_PORT=80

# PostgreSQL
DB_HOST_PORT=5432
DB_REPLICA_HOST_PORT=5433
DB_PORT=5432
DB_READ_PORT=5432
DB_NAME=chatdb
DB_USERNAME=chatuser
DB_PASSWORD=chatpass
DB_TIMEZONE=Asia/Seoul
POSTGRES_REPLICATION_USER=chat_replicator
POSTGRES_REPLICATION_PASSWORD=replicatorpass
POSTGRES_MAX_WAL_SENDERS=10
POSTGRES_MAX_REPLICATION_SLOTS=10
POSTGRES_WAL_KEEP_SIZE=512MB
CHAT_MESSAGE_RETENTION_DAYS=100
CHAT_PARTITION_ARCHIVE_DROP_AFTER_COPY=false
CHAT_PARTITION_ARCHIVE_RUN_ONCE=false
CHAT_PARTITION_ARCHIVE_INTERVAL_SECONDS=86400

# Redis
REDIS_HOST_PORT=6379
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend application config
CHAT_API_CORS_ALLOWED_ORIGINS=*
CHAT_WEBSOCKET_ALLOWED_ORIGINS=*
CHAT_WEBSOCKET_ENDPOINT=/ws/chat
CHAT_MESSAGE_PAGINATION_DEFAULT_LIMIT=50
CHAT_MESSAGE_PAGINATION_MAX_LIMIT=100
CHAT_MESSAGE_SEQUENCE_TTL=24h
CHAT_CACHE_DEFAULT_TTL=30m
CHAT_CACHE_USERS_TTL=1h
CHAT_CACHE_CHAT_ROOMS_TTL=15m
CHAT_CACHE_CHAT_ROOM_MEMBERS_TTL=10m
CHAT_CACHE_MESSAGES_TTL=5m
